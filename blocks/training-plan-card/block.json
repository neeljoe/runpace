{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "runpace/training-plan-card",
	"version": "1.0.0",
	"title": "Training Plan Card",
	"category": "runpace",
	"description": "Displays a training plan with level badge, stats grid, and download CTA.",
	"keywords": [ "training", "plan", "card", "running" ],
	"textdomain": "runpace",
	"attributes": {
		"colorScheme": { "type": "string", "default": "default", "enum": ["default","dark","green","orange"] },
		"showDownload": { "type": "boolean", "default": true },
		"showStats": { "type": "boolean", "default": true }
	},
	"usesContext": [ "postId", "postType" ],
	"supports": {
		"html": false,
		"interactivity": { "clientNavigation": true }
	},
	"render": "file:./render.php",
	"editorScript": "file:./src/index.js",
	"style": "file:./src/style.css"
}