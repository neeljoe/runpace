{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "runpace/stats-highlight",
	"version": "1.0.0",
	"title": "Stats Highlight",
	"category": "runpace",
	"description": "Animated stats strip: e.g. 42KM · 10,000+ runners · 50 countries.",
	"keywords": [ "stats", "numbers", "highlight", "counter" ],
	"textdomain": "runpace",
	"attributes": {
		"stats": {
			"type": "array",
			"default": [
				{ "value": "42KM",    "label": "Full marathon", "icon": "🏃" },
				{ "value": "10K+",    "label": "Runners listed", "icon": "👥" },
				{ "value": "50",      "label": "Countries",      "icon": "🌍" },
				{ "value": "200+",    "label": "Race events",    "icon": "🏅" }
			]
		},
		"theme": {
			"type": "string",
			"default": "dark",
			"enum": [ "dark", "light", "primary", "split" ]
		},
		"animateOnScroll": { "type": "boolean", "default": true }
	},
	"supports": {
		"html": false,
		"color": { "background": true, "text": true },
		"spacing": { "padding": true, "margin": true },
		"interactivity": true
	},
	"render": "file:./render.php",
	"editorScript": "file:./src/index.js",
	"viewScriptModule": "file:./src/view.js",
	"style": "file:./src/style.css"
}