{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "runpace/stats-highlight",
	"version": "1.0.0",
	"title": "Stats Highlight",
	"category": "runpace",
	"icon": "chart-bar",
	"description": "A visually bold stats strip — e.g. '42KM', '10,000+ runners', '50 countries'. Perfect for hero sections and landing pages.",
	"keywords": [ "stats", "numbers", "highlight", "counter", "achievements" ],
	"textdomain": "runpace",
	"example": {
		"attributes": {
			"stats": [
				{ "value": "42KM",    "label": "Full marathon",    "icon": "🏃" },
				{ "value": "10,000+", "label": "Runners joined",   "icon": "👥" },
				{ "value": "50",      "label": "Countries",        "icon": "🌍" },
				{ "value": "98%",     "label": "Finish rate",      "icon": "🏅" }
			]
		}
	},

	"attributes": {
		"stats": {
			"type": "array",
			"default": [
				{ "value": "42KM",    "label": "Full marathon",    "icon": "🏃" },
				{ "value": "10,000+", "label": "Runners joined",   "icon": "👥" },
				{ "value": "50",      "label": "Countries",        "icon": "🌍" },
				{ "value": "98%",     "label": "Finish rate",      "icon": "🏅" }
			],
			"items": {
				"type": "object",
				"properties": {
					"value": { "type": "string" },
					"label": { "type": "string" },
					"icon":  { "type": "string" }
				}
			}
		},
		"layout": {
			"type":    "string",
			"default": "grid",
			"enum":    [ "grid", "row", "stacked" ]
		},
		"theme": {
			"type":    "string",
			"default": "dark",
			"enum":    [ "light", "dark", "brand", "transparent" ]
		},
		"textAlign": {
			"type":    "string",
			"default": "center"
		},
		"showDividers": {
			"type":    "boolean",
			"default": true
		}
	},

	"supports": {
		"html":  false,
		"align": [ "wide", "full" ],
		"color": {
			"background": true,
			"text":       true,
			"gradients":  true
		},
		"spacing": {
			"padding": true,
			"margin":  true
		},
		"typography": {
			"fontSize": false
		},
		"anchor": true
	},

	"style":        "file:./build/style.css",
	"editorStyle":  "file:./build/editor.css",
	"editorScript": "file:./build/index.js",
	"render":       "file:./render.php",
	"viewScript":   "file:./build/view.js"
}