{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "runpace/marathon-info",
	"version": "1.0.0",
	"title": "Marathon Info",
	"category": "runpace",
	"description": "Displays key marathon meta: date, location, distance, price, elevation, and difficulty rating.",
	"keywords": [ "marathon", "race", "running", "info" ],
	"textdomain": "runpace",

	"attributes": {
		"layout":             { "type": "string",  "default": "grid", "enum": [ "grid", "compact", "hero" ] },
		"showCountdown":      { "type": "boolean", "default": true },
		"showRegisterButton": { "type": "boolean", "default": true },
		"registerLabel":      { "type": "string",  "default": "Register Now" },
		"accentColor":        { "type": "string",  "default": "primary" }
	},

	"usesContext": [ "postId", "postType" ],

	"supports": {
		"html": false,
		"color":   { "background": true, "text": true },
		"spacing": { "padding": true, "margin": true },
		"interactivity": { "clientNavigation": true }
	},

	"render":       "file:./render.php",
	"editorScript": "file:./build/index.js",
	"editorStyle":  "file:./build/index.css",
	"style":        "file:./build/style-index.css"
}